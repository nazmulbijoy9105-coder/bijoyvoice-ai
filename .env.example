# Copy to .env.local for local dev (never commit .env.local).

# Required — Google AI Studio: https://aistudio.google.com/app/apikey
GEMINI_API_KEY=

# Optional — exact model id (recommended). Same value in Vercel Environment Variables.
# Correct spelling (hyphens, no spaces):
#   gemini-1.5-flash
#   gemini-2.0-flash
#   gemini-1.5-pro
# If you omit this, the app tries gemini-1.5-flash first, then others.
GEMINI_MODEL=gemini-1.5-flash

# Optional — your public site URL for SEO / Open Graph (browser + build metadata only).
# Does NOT talk to Gemini. Example: https://bijoyvoice-ai.vercel.app
NEXT_PUBLIC_SITE_URL=
